<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Buttons Bebe — Support Console</title>
<style>
*{box-sizing:border-box;margin:0}
:root{
/* ---- brand (purple) ---- */
--acc:#6d5efc;--acc-strong:#5b4de0;--acc-hover:#4d40cf;--acc-ink:#5546d6;--acc-soft:#f1eefe;--acc-100:#e7e2fd;
/* ---- neutral ramp ---- */
--gray-0:#ffffff;--gray-25:#fafbfd;--gray-50:#f6f7fb;--gray-100:#eef0f5;--gray-200:#e5e7ef;--gray-300:#cfd4df;--gray-400:#9aa2b1;--gray-500:#6b7382;--gray-600:#4a5262;--gray-700:#333a47;--gray-900:#14161c;
/* ---- semantic aliases (kept names) ---- */
--ink:#14161c;--ink2:#4a5262;--ink3:#6b7382;--bg:#f6f7fb;--card:#ffffff;--line:#e5e7ef;
--green:#12b76a;--green-ink:#0a7a48;--green-s:#e7f7ee;
--amber:#e08c00;--amber-ink:#8a5a06;--amber-s:#fdf3e0;
--red:#e5484d;--red-ink:#b42318;--red-s:#fdecec;
/* ---- radius scale ---- */
--r-xs:6px;--r-sm:8px;--r-md:10px;--r-lg:14px;--radius:14px;--r-pill:999px;
/* ---- elevation ---- */
--sh-xs:0 1px 2px rgba(20,22,28,.05);
--sh-sm:0 1px 2px rgba(20,22,28,.04),0 1px 3px rgba(20,22,28,.06);
--sh-md:0 2px 6px -2px rgba(20,22,28,.06),0 8px 20px -6px rgba(20,22,28,.12);
--sh-lg:0 14px 34px -10px rgba(20,22,28,.20);
--ring:0 0 0 3px rgba(109,94,252,.30);
/* ---- motion ---- */
--ease:cubic-bezier(.4,0,.2,1);--dur:.18s;--dur-fast:.12s;
font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Inter,"Helvetica Neue",Arial,sans-serif}
body{background:var(--bg);color:var(--ink);-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility;font-size:14px;line-height:1.5}
button{font-family:inherit}
:focus-visible{outline:none;box-shadow:var(--ring)}
::selection{background:var(--acc-100)}
#app{display:flex;min-height:100vh}

/* ============ SIDEBAR ============ */
.side{width:236px;flex:0 0 236px;background:var(--card);border-right:1px solid var(--line);padding:20px 14px;display:flex;flex-direction:column}
.logo{display:flex;align-items:center;gap:10px;padding:4px 6px 18px;flex-wrap:wrap}
.logo .mark{width:32px;height:32px;border-radius:10px;background:linear-gradient(150deg,var(--acc),var(--acc-hover));color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:16px;box-shadow:var(--sh-sm)}
.logo b{font-size:15px;font-weight:700;letter-spacing:-.01em}
.logo .tag{font-size:10px;color:var(--acc-ink);background:var(--acc-soft);padding:3px 7px;border-radius:var(--r-pill);font-weight:600;letter-spacing:.03em;text-transform:uppercase}
.nav{display:flex;flex-direction:column;gap:2px;margin-top:4px}
.nav a{display:flex;align-items:center;gap:11px;padding:9px 11px;border-radius:var(--r-sm);color:var(--ink2);font-size:14px;cursor:pointer;font-weight:500;position:relative;transition:background var(--dur-fast) var(--ease),color var(--dur-fast) var(--ease)}
.nav a:hover{background:var(--gray-100);color:var(--ink)}
.nav a.on{background:var(--acc-soft);color:var(--acc-ink);font-weight:600}
.nav a.on::before{content:"";position:absolute;left:3px;top:50%;transform:translateY(-50%);width:3px;height:16px;border-radius:3px;background:var(--acc)}
.nav a svg{width:18px;height:18px;flex:0 0 18px}
.side .store{margin-top:auto;border-top:1px solid var(--line);padding-top:14px;display:flex;align-items:center;gap:10px}
.side .store .av{width:34px;height:34px;border-radius:9px;background:var(--gray-100);display:flex;align-items:center;justify-content:center;font-weight:700;color:var(--ink2)}
.side .store .nm{font-size:13px;font-weight:600}
.side .store .pl{font-size:12px;color:var(--ink3)}

/* ============ MAIN + TOPBAR ============ */
.main{flex:1;min-width:0;display:flex;flex-direction:column}
.top{display:flex;align-items:center;justify-content:space-between;gap:16px;padding:18px 28px;border-bottom:1px solid var(--line);background:rgba(255,255,255,.86);backdrop-filter:saturate(1.1) blur(8px);position:sticky;top:0;z-index:20}
.top h1{font-size:20px;font-weight:700;letter-spacing:-.01em}
.top .sub{font-size:13px;color:var(--ink3);margin-top:3px}
.topact{display:flex;align-items:center;gap:10px}
.live{display:inline-flex;align-items:center;gap:7px;font-size:13px;background:var(--green-s);color:var(--green-ink);padding:6px 12px;border-radius:var(--r-pill);font-weight:600}
.dot{width:8px;height:8px;border-radius:50%;background:var(--green);display:inline-block;position:relative}
.live .dot::after{content:"";position:absolute;inset:0;border-radius:50%;background:var(--green);opacity:.4;animation:pulse 2s var(--ease) infinite}
@keyframes pulse{0%{transform:scale(1);opacity:.4}70%{transform:scale(2.6);opacity:0}100%{opacity:0}}
.iconbtn{width:36px;height:36px;display:inline-flex;align-items:center;justify-content:center;border:1px solid var(--line);background:var(--card);border-radius:var(--r-sm);color:var(--ink2);cursor:pointer;transition:background var(--dur-fast) var(--ease),color var(--dur-fast) var(--ease),border-color var(--dur-fast) var(--ease)}
.iconbtn:hover{background:var(--gray-100);color:var(--ink);border-color:var(--gray-300)}
.iconbtn svg{width:17px;height:17px}
.wrap{padding:24px 28px;overflow:auto;flex:1}

/* ============ KPI CARDS ============ */
.kpis{display:grid;grid-template-columns:repeat(auto-fit,minmax(184px,1fr));gap:14px}
.kpi{background:var(--card);border:1px solid var(--line);border-radius:var(--r-lg);padding:18px 20px;box-shadow:var(--sh-sm);transition:transform var(--dur) var(--ease),box-shadow var(--dur) var(--ease)}
.kpi:hover{transform:translateY(-2px);box-shadow:var(--sh-md)}
.kpi:first-child{background:linear-gradient(158deg,var(--acc-soft),#fff 72%);border-color:var(--acc-100)}
.kpi .l{font-size:12px;color:var(--ink3);font-weight:600;text-transform:uppercase;letter-spacing:.04em}
.kpi .v{font-size:30px;font-weight:700;letter-spacing:-.02em;margin:10px 0 5px;line-height:1}
.kpi:first-child .v{color:var(--acc-ink)}
.kpi .s{font-size:13px;color:var(--ink2);font-weight:500}
.kpi .s.up{color:var(--green-ink)}
.kpi .s.dn{color:var(--red-ink)}

/* ============ PANELS + LAYOUT ============ */
.grid2{display:grid;grid-template-columns:1.4fr 1fr;gap:16px;margin-top:16px}
.panel{background:var(--card);border:1px solid var(--line);border-radius:var(--r-lg);padding:20px 22px;box-shadow:var(--sh-sm)}
.panel h3{font-size:15px;font-weight:700;letter-spacing:-.01em;margin-bottom:3px}
.panel .ph{font-size:13px;color:var(--ink3);margin-bottom:16px;line-height:1.45}

/* horizontal bar chart */
.hb{display:flex;flex-direction:column;gap:13px;padding-top:4px}
.hb .r{display:flex;align-items:center;gap:12px;font-size:13px}
.hb .r .lab{width:80px;flex:0 0 80px;color:var(--ink2);font-weight:500}
.hb .r .track{flex:1;height:10px;background:var(--gray-100);border-radius:var(--r-pill);overflow:hidden}
.hb .r .fill{height:100%;border-radius:var(--r-pill);transition:width .6s var(--ease)}
.hb .r .n{width:28px;text-align:right;color:var(--ink);font-weight:700}

/* activity list */
.act{display:flex;flex-direction:column}
.act .r{display:flex;gap:12px;align-items:flex-start;font-size:13px;padding:10px 0;border-top:1px solid var(--line)}
.act .r:first-child{border-top:none;padding-top:2px}
.act .r .ic{width:28px;height:28px;border-radius:var(--r-sm);flex:0 0 28px;display:flex;align-items:center;justify-content:center;margin-top:1px}
.act .r .ic.g{background:var(--green-s);color:var(--green-ink)}
.act .r .ic.a{background:var(--amber-s);color:var(--amber-ink);font-weight:700}
.act .r .ic svg{width:15px;height:15px}
.act .r .tm{color:var(--ink3);font-size:12px;margin-left:auto;white-space:nowrap;font-weight:500}

/* filter chips */
.filters{display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap}
.chip{font-size:13px;padding:7px 14px;border-radius:var(--r-pill);border:1px solid var(--line);background:var(--card);color:var(--ink2);cursor:pointer;font-weight:600;transition:background var(--dur-fast) var(--ease),color var(--dur-fast) var(--ease),border-color var(--dur-fast) var(--ease)}
.chip:hover{border-color:var(--gray-300);color:var(--ink)}
.chip.on{background:var(--acc-strong);border-color:var(--acc-strong);color:#fff}
.chip.on:hover{color:#fff}

/* ticket feed */
.tk{background:var(--card);border:1px solid var(--line);border-radius:var(--r-lg);overflow:hidden;box-shadow:var(--sh-sm)}
.tk .row{display:flex;align-items:center;gap:14px;padding:14px 18px;border-top:1px solid var(--line);cursor:pointer;transition:background var(--dur-fast) var(--ease)}
.tk .row:first-child{border-top:none}
.tk .row:hover{background:var(--gray-25)}
.tk .row.open{background:var(--gray-25);box-shadow:inset 3px 0 var(--acc)}
.tk .who{width:180px;flex:0 0 180px;min-width:0}
.tk .who b{font-size:14px;font-weight:600;display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.tk .who small{font-size:12px;color:var(--ink3)}
.tk .subj{flex:1;min-width:0;font-size:14px;color:var(--ink2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.badge{font-size:12px;font-weight:600;padding:4px 10px;border-radius:var(--r-pill);white-space:nowrap;display:inline-flex;align-items:center;gap:6px}
.badge::before{content:"";width:6px;height:6px;border-radius:50%;background:currentColor}
.badge.low{background:var(--green-s);color:var(--green-ink)}
.badge.sens{background:var(--amber-s);color:var(--amber-ink)}
.st{font-size:12px;color:var(--ink3);width:104px;text-align:right;flex:0 0 104px}
.st b{color:var(--ink2);font-weight:600}
.chev{flex:0 0 18px;color:var(--gray-400);display:inline-flex;align-items:center;justify-content:center;transition:transform var(--dur) var(--ease),color var(--dur) var(--ease)}
.chev svg{width:18px;height:18px}
.tk .row.open .chev{transform:rotate(180deg);color:var(--acc-ink)}

/* ticket detail */
.detail{padding:12px 26px 24px;border-top:1px solid var(--line);background:var(--gray-25)}
.detail .dwrap{max-width:860px}
.detail .lab{font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:var(--ink3);font-weight:700;margin:0 0 8px}
.detail .lab.lab2{margin-top:20px}
.detail .msg{font-size:14px;color:var(--ink);line-height:1.62;white-space:pre-wrap;word-break:break-word;max-height:260px;overflow:auto;background:var(--card);border:1px solid var(--line);border-radius:var(--r-md);padding:14px 16px}
.linkbtn{background:none;border:none;color:var(--acc-ink);font-size:13px;font-weight:600;cursor:pointer;padding:8px 0 0}
.linkbtn:hover{text-decoration:underline}
.pill{font-size:10px;font-weight:700;letter-spacing:.05em;background:var(--gray-100);color:var(--ink2);padding:2px 7px;border-radius:var(--r-pill);margin-left:5px;vertical-align:1px}
.sendhint{font-size:12px;color:var(--ink3);text-align:right;margin-top:8px}
.detail .draft{font-size:14px;color:var(--ink);line-height:1.65;background:var(--card);border:1px solid var(--line);border-radius:var(--r-md);padding:14px 16px;white-space:pre-wrap}
.detail .draft.esc{background:var(--amber-s);border-color:#f3dfb0;color:var(--amber-ink)}
.warn{background:var(--amber-s);color:var(--amber-ink);border:1px solid #f3dfb0;border-radius:var(--r-sm);padding:10px 13px;font-size:13px;margin-bottom:10px;font-weight:600;display:flex;gap:8px;align-items:flex-start}
.dedit{width:100%;min-height:168px;font-family:inherit;font-size:14px;line-height:1.6;border:1px solid var(--line);border-radius:var(--r-md);padding:13px;color:var(--ink);background:var(--card);resize:vertical;transition:border-color var(--dur-fast) var(--ease),box-shadow var(--dur-fast) var(--ease)}
.dedit:focus{outline:none;border-color:var(--acc);box-shadow:var(--ring)}
.actbar{display:flex;align-items:center;gap:8px;margin-top:14px;padding-top:14px;border-top:1px solid var(--line);flex-wrap:wrap}
.actbar .toast{margin-right:auto;color:var(--ink2);font-size:13px;font-weight:500}
.editbox{margin-top:12px;background:var(--card);border:1px solid var(--line);border-radius:var(--r-md);padding:14px}
.editact{display:flex;gap:8px;margin-top:10px}

/* buttons */
.btn{font-size:13px;font-weight:600;padding:9px 16px;border-radius:var(--r-sm);border:1px solid var(--line);background:var(--card);color:var(--ink);cursor:pointer;transition:background var(--dur-fast) var(--ease),border-color var(--dur-fast) var(--ease),transform var(--dur-fast) var(--ease);white-space:nowrap}
.btn:hover{border-color:var(--gray-300);background:var(--gray-25)}
.btn:active{transform:translateY(1px)}
.btn:disabled{opacity:.55;cursor:default;transform:none}
.btn.p{background:var(--acc-strong);border-color:var(--acc-strong);color:#fff;box-shadow:var(--sh-xs)}
.btn.p:hover{background:var(--acc-hover);border-color:var(--acc-hover)}
.btn.send{background:var(--green);border-color:var(--green);color:#fff;box-shadow:var(--sh-xs)}
.btn.send:hover{background:#0ea25c;border-color:#0ea25c}
.btn.ghost{border-color:transparent;background:none;color:var(--ink2)}
.btn.ghost:hover{background:var(--gray-100);border-color:transparent;color:var(--ink)}

/* learning stats */
.lrow{display:grid;grid-template-columns:repeat(auto-fit,minmax(128px,1fr));gap:14px;margin-top:6px}
.lstat{background:var(--gray-25);border:1px solid var(--line);border-radius:var(--r-md);padding:15px 16px}
.lstat .v{font-size:26px;font-weight:700;letter-spacing:-.02em}
.lstat .l{font-size:12px;color:var(--ink3);margin-top:3px;font-weight:500}

/* connections */
.conns{display:grid;grid-template-columns:repeat(auto-fit,minmax(264px,1fr));gap:14px}
.conn{background:var(--card);border:1px solid var(--line);border-radius:var(--r-lg);padding:18px 20px;box-shadow:var(--sh-sm);transition:transform var(--dur) var(--ease),box-shadow var(--dur) var(--ease)}
.conn:hover{transform:translateY(-2px);box-shadow:var(--sh-md)}
.conn .h{display:flex;align-items:center;gap:12px;margin-bottom:12px}
.conn .ic{width:40px;height:40px;border-radius:var(--r-md);background:var(--acc-soft);color:var(--acc-ink);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;flex:0 0 40px}
.conn .h b{font-size:15px;font-weight:600;display:block}
.conn .h small{font-size:12px;color:var(--ink3)}
.conn .stt{display:inline-flex;align-items:center;gap:7px;font-size:13px;color:var(--green-ink);background:var(--green-s);padding:5px 11px;border-radius:var(--r-pill);font-weight:600;margin-top:2px}
.conn .dt{font-size:13px;color:var(--ink2);margin-top:12px;line-height:1.45}

/* onboarding steps */
.steps{display:flex;flex-direction:column}
.step{display:flex;align-items:center;gap:13px;padding:13px 0;border-top:1px solid var(--line);font-size:14px}
.step:first-child{border-top:none}
.step .ck{width:24px;height:24px;border-radius:50%;background:var(--green);color:#fff;display:flex;align-items:center;justify-content:center;flex:0 0 24px;box-shadow:var(--sh-xs)}
.step .ck svg{width:14px;height:14px}
.step b{font-weight:600}
.step small{color:var(--ink3);font-size:13px;display:block;margin-top:1px}

/* toggle switch */
.toggle{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:16px 18px;border:1px solid var(--line);border-radius:var(--r-md);max-width:540px;background:var(--card);box-shadow:var(--sh-sm)}
.sw{width:44px;height:26px;border-radius:var(--r-pill);background:var(--gray-300);position:relative;cursor:pointer;flex:0 0 44px;transition:background var(--dur) var(--ease)}
.sw.on{background:var(--acc-strong)}
.sw i{position:absolute;top:3px;left:3px;width:20px;height:20px;border-radius:50%;background:#fff;transition:left var(--dur) var(--ease);box-shadow:var(--sh-sm)}
.sw.on i{left:21px}

/* settings chips */
.chips{display:flex;gap:8px;flex-wrap:wrap}
.chips span{font-size:13px;background:var(--gray-100);color:var(--ink2);padding:6px 12px;border-radius:var(--r-pill);font-weight:500}

/* misc */
.sec-title{font-size:12px;text-transform:uppercase;letter-spacing:.05em;color:var(--ink3);font-weight:700;margin:28px 0 12px}
.hint{font-size:13px;color:var(--ink3);line-height:1.5}
.empty{padding:44px 26px;color:var(--ink3);font-size:14px;text-align:center}
.rixbar{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:16px;flex-wrap:wrap}

/* knowledge base */
.kbwrap{display:grid;grid-template-columns:260px 1fr;gap:16px}
.kblist{background:var(--card);border:1px solid var(--line);border-radius:var(--r-lg);padding:10px;max-height:72vh;overflow:auto;box-shadow:var(--sh-sm)}
.kbgroup{margin-bottom:6px}
.kbgroup .gh{font-size:11px;text-transform:uppercase;letter-spacing:.04em;color:var(--ink3);font-weight:700;padding:9px 9px 5px;display:flex;justify-content:space-between;align-items:center}
.kbgroup .gh button{font-size:11px;color:var(--acc-ink);background:none;border:none;cursor:pointer;font-weight:700;padding:2px 5px;border-radius:var(--r-xs)}
.kbgroup .gh button:hover{background:var(--acc-soft)}
.kbitem{display:block;width:100%;text-align:left;padding:8px 10px;border-radius:var(--r-sm);font-size:13px;color:var(--ink2);cursor:pointer;border:none;background:none;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;transition:background var(--dur-fast) var(--ease),color var(--dur-fast) var(--ease)}
.kbitem:hover{background:var(--gray-100);color:var(--ink)}
.kbitem.on{background:var(--acc-soft);color:var(--acc-ink);font-weight:600}
.kbed{background:var(--card);border:1px solid var(--line);border-radius:var(--r-lg);padding:18px 20px;display:flex;flex-direction:column;min-height:60vh;box-shadow:var(--sh-sm)}
.kbed .eh{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:12px}
.kbed .eh b{font-size:13px;color:var(--ink2);font-family:ui-monospace,Menlo,monospace;background:var(--gray-100);padding:4px 9px;border-radius:var(--r-xs)}
.kbed .ef{display:flex;align-items:center;gap:12px}
.kbed textarea{width:100%;flex:1;min-height:50vh;font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:13px;line-height:1.6;border:1px solid var(--line);border-radius:var(--r-md);padding:14px;color:var(--ink);resize:vertical;background:var(--gray-25);transition:border-color var(--dur-fast) var(--ease),box-shadow var(--dur-fast) var(--ease)}
.kbed textarea:focus{outline:none;border-color:var(--acc);box-shadow:var(--ring);background:var(--card)}
.toast{font-size:13px;color:var(--green-ink);font-weight:500}
.ph2{color:var(--ink3);font-size:14px;padding:38px;text-align:center}

/* accounts strip / notifications */
.acctstrip{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:16px}
.acct{display:flex;align-items:center;gap:8px;background:var(--card);border:1px solid var(--line);border-radius:var(--r-pill);padding:8px 14px;font-size:13px;font-weight:600;color:var(--ink2);box-shadow:var(--sh-xs)}
.acct small{color:var(--ink3);font-size:11px;font-weight:500}
.dot.off{background:var(--amber)}
.grid2b{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.wc-ok{display:flex;align-items:center;gap:12px}
.wc-ok .ic{width:32px;height:32px;border-radius:var(--r-sm);flex:0 0 32px;display:flex;align-items:center;justify-content:center}
.wc-ok .ic.g{background:var(--green-s);color:var(--green-ink)}
.wc-ok .ic svg{width:16px;height:16px}
.wc-ok b{font-size:14px}
.wc-ok button{margin-left:auto}
.wc-qr{text-align:center;padding:8px 0}
.wc-qr img{width:230px;height:230px;background:#fff;border-radius:var(--r-md);padding:10px;border:1px solid var(--line);box-shadow:var(--sh-sm)}
.steps2{text-align:left;max-width:250px;margin:14px auto 0;font-size:13px;color:var(--ink2);padding-left:18px}
.steps2 li{margin:5px 0}
.destbox{display:flex;flex-direction:column;gap:10px}
.dopt{display:flex;gap:10px;align-items:flex-start;border:1px solid var(--line);border-radius:var(--r-md);padding:12px 14px;cursor:pointer;transition:border-color var(--dur-fast) var(--ease),background var(--dur-fast) var(--ease)}
.dopt:hover{border-color:var(--gray-300)}
.dopt.on{border-color:var(--acc);background:var(--acc-soft)}
.dopt input{margin-top:3px;accent-color:var(--acc-strong)}
.dopt b{font-size:14px;display:block}
.dopt small{font-size:12px;color:var(--ink3)}
.numin{border:1px solid var(--line);border-radius:var(--r-sm);padding:11px 13px;font-size:14px;color:var(--ink);width:100%;background:var(--card);transition:border-color var(--dur-fast) var(--ease),box-shadow var(--dur-fast) var(--ease)}
.numin:focus{outline:none;border-color:var(--acc);box-shadow:var(--ring)}
.numin:disabled{background:var(--gray-100);color:var(--ink3)}
.destact{display:flex;align-items:center;gap:10px;margin-top:4px;flex-wrap:wrap}
.destact .toast{margin-right:auto}
.spin{display:inline-block;width:12px;height:12px;border:2px solid var(--gray-200);border-top-color:var(--acc);border-radius:50%;animation:sp .8s linear infinite;vertical-align:-2px}
@keyframes sp{to{transform:rotate(360deg)}}

/* ============ RESPONSIVE ============ */
@media(max-width:900px){
 .grid2{grid-template-columns:1fr}
 #app{flex-direction:column}
 .side{width:100%;flex:0 0 auto;flex-direction:row;align-items:center;gap:6px;padding:10px 12px;border-right:none;border-bottom:1px solid var(--line);overflow-x:auto}
 .logo{padding:2px 6px;flex-wrap:nowrap}
 .logo .tag{display:none}
 .nav{flex-direction:row;margin-top:0;gap:4px;flex:1;justify-content:flex-end}
 .nav a{padding:9px}
 .nav a span{display:none}
 .nav a.on::before{display:none}
 .side .store{display:none}
 .top{padding:16px 18px}
 .wrap{padding:18px}
}
@media(max-width:820px){.kbwrap{grid-template-columns:1fr}.grid2b{grid-template-columns:1fr}}
/* accessibility follow-ups */
.sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;border:0}
.iconbtn.spinning svg{animation:sp .8s linear infinite}
.iconbtn:disabled{opacity:.7;cursor:default}
.tk .row:focus-visible{box-shadow:inset 0 0 0 2px var(--acc)}
.conn .ic svg{width:20px;height:20px}
.warn svg{width:16px;height:16px;flex:0 0 16px;margin-top:1px}
</style>
</head>
<body>
<div id="app"><div class="empty"><span class="spin"></span> Loading your support console…</div></div>
<script>
const API="/console/api", KBAPI="/console/kbapi";
let stats={},tickets=[],settings={},learn={},tab="overview",openTk=null,filter="all";
let kbData=null,kbSel=null,kbBuf="",kbMsg="",kbReindexing=false;
let waData=null,waMsg="",waMode=null,waNumber=null,waPoll=null;
const WAAPI="/console/waapi";
let actDraft="",actInstr="",actEditOpen=false,actMsg="",actBusy=false,actShowRaw=false;

const IC={
 overview:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="9" rx="1.5"/><rect x="14" y="3" width="7" height="5" rx="1.5"/><rect x="14" y="12" width="7" height="9" rx="1.5"/><rect x="3" y="16" width="7" height="5" rx="1.5"/></svg>',
 tickets:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6a2 2 0 012-2h12a2 2 0 012 2v8a2 2 0 01-2 2H9l-4 3v-3H6a2 2 0 01-2-2V6z"/><path d="M8 9h8M8 12h5"/></svg>',
 conns:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 14.5l5-5"/><path d="M11 6.5l1-1a4 4 0 015.7 5.7l-1 1"/><path d="M13 17.5l-1 1a4 4 0 01-5.7-5.7l1-1"/></svg>',
 kb:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 5a2 2 0 012-2h13v16H6a2 2 0 00-2 2V5z"/><path d="M4 19a2 2 0 012-2h13"/></svg>',
 notif:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 8a6 6 0 1112 0c0 6 2 7 2 7H4s2-1 2-7z" stroke-linejoin="round"/><path d="M10 20a2 2 0 004 0"/></svg>',
 settings:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="3"/><path d="M19 12a7 7 0 00-.1-1l2-1.5-2-3.4-2.3 1a7 7 0 00-1.7-1L14.5 3h-4l-.4 2.6a7 7 0 00-1.7 1l-2.3-1-2 3.4L4.1 11a7 7 0 000 2l-2 1.5 2 3.4 2.3-1a7 7 0 001.7 1l.4 2.6h4l.4-2.6a7 7 0 001.7-1l2.3 1 2-3.4-2-1.5c.1-.3.1-.7.1-1z"/></svg>',
 check:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12l5 5L20 6" stroke-linecap="round" stroke-linejoin="round"/></svg>',
 refresh:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 11a8 8 0 10-2.3 5.7M20 5v6h-6" stroke-linecap="round" stroke-linejoin="round"/></svg>',
 chev:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>',
 alert:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10.3 4.4L2.5 18a2 2 0 001.7 3h15.6a2 2 0 001.7-3L13.7 4.4a2 2 0 00-3.4 0z"/><path d="M12 9.5v4"/><path d="M12 17h.01"/></svg>',
 gorgias:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 13v-1a8 8 0 0116 0v1"/><rect x="2.5" y="13" width="4.5" height="6.5" rx="1.6"/><rect x="17" y="13" width="4.5" height="6.5" rx="1.6"/><path d="M20 19.5a4 4 0 01-4 4h-2.5"/></svg>',
 shopify:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6.5 8h11l-1 11.5a1.5 1.5 0 01-1.5 1.4H9a1.5 1.5 0 01-1.5-1.4L6.5 8z"/><path d="M9 8V6.5a3 3 0 016 0V8"/></svg>',
 redo:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 14l-4-4 4-4"/><path d="M5 10h9.5a4.5 4.5 0 010 9H8"/></svg>',
 whatsapp:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 11.5a7.5 7.5 0 01-11.1 6.6L4.5 19.5l1.4-4.3A7.5 7.5 0 1120 11.5z"/><path d="M9 11.6h.01M12 11.6h.01M15 11.6h.01"/></svg>'
};
const esc=s=>(s==null?"":String(s)).replace(/[&<>]/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;"}[c]));
const keyClick=el=>{if(el)el.onkeydown=e=>{if(e.key==="Enter"||e.key===" "){e.preventDefault();el.click();}};};
let _live=null;
function announce(m){if(!m)return;if(!_live){_live=document.createElement("div");_live.id="sr-live";_live.setAttribute("aria-live","polite");_live.setAttribute("role","status");_live.className="sr-only";document.body.appendChild(_live);}_live.textContent="";setTimeout(()=>{_live.textContent=m;},60);}
const nameOf=t=>{const e=t.customer_email||"";return e?e.split("@")[0].replace(/[._]/g," ").replace(/\b\w/g,c=>c.toUpperCase()):"Customer";};
const isEsc=t=>{const a=(t.action||"").toLowerCase(),p=(t.priority||"").toUpperCase();return a.includes("escal")||p==="IMMEDIATE"||p==="CRITICAL"||p==="HIGH";};
const ago=t=>{const d=t.processed_at||t.created_at;if(!d)return"";const s=(Date.now()-new Date(d).getTime())/1000;if(s<60)return"just now";if(s<3600)return Math.floor(s/60)+"m ago";if(s<86400)return Math.floor(s/3600)+"h ago";return Math.floor(s/86400)+"d ago";};
async function jget(u){try{const r=await fetch(u,{cache:"no-store"});if(!r.ok)return null;return await r.json();}catch(e){return null;}}

async function boot(){
 const [s,t,st,lg]=await Promise.all([jget(API+"/stats"),jget(API+"/tickets?limit=60"),jget(API+"/settings"),jget(API+"/learning")]);
 stats=s||{};tickets=Array.isArray(t)?t:[];settings=st||{};learn=lg||{};
 render();
}

function render(){
 const pages={overview:"Overview",tickets:"Ticket feed",conns:"Connections",kb:"Knowledge base",notif:"Notifications",settings:"Settings"};
 const subs={overview:"How your AI support agent is performing",tickets:"Every ticket, its AI draft, and what needs you",conns:"Your connected tools and their health",kb:"Edit what your agent knows — policies, FAQs, intents, tickets",notif:"Link WhatsApp and choose where alerts go",settings:"Configure your agent"};
 document.getElementById("app").innerHTML=`
  <aside class="side">
    <div class="logo"><div class="mark">B</div><b>Buttons Bebe</b><span class="tag">support AI</span></div>
    <nav class="nav">${Object.keys(pages).map(k=>`<a data-tab="${k}" role="button" tabindex="0" aria-current="${tab===k?'page':'false'}" class="${tab===k?'on':''}">${IC[k]}<span>${pages[k]}</span></a>`).join("")}</nav>
    <div class="store"><div class="av">B</div><div><div class="nm">Buttons Bebe</div><div class="pl">Hermes agent</div></div></div>
  </aside>
  <div class="main">
    <div class="top"><div><h1>${pages[tab]}</h1><div class="sub">${subs[tab]}</div></div>
      <div class="topact"><div class="live"><span class="dot"></span> Agent live</div><button class="iconbtn" id="refresh" title="Refresh" aria-label="Refresh data">${IC.refresh}</button></div></div>
    <div class="wrap">${view()}</div>
  </div>`;
 document.querySelectorAll(".nav a").forEach(a=>{a.onclick=()=>{tab=a.dataset.tab;openTk=null;stopWaPoll();if(tab==="kb"&&!kbData){loadKb();}else if(tab==="notif"){loadWa();}else{render();}};keyClick(a);});
 const rf=document.getElementById("refresh");if(rf)rf.onclick=async()=>{rf.classList.add("spinning");rf.disabled=true;if(tab==="kb"){kbData=null;await loadKb();}else if(tab==="notif"){await loadWa();}else{await boot();}};
 bind();
}
function view(){return tab==="overview"?overview():tab==="tickets"?ticketsView():tab==="conns"?conns():tab==="kb"?kbView():tab==="notif"?waView():settingsView();}

function overview(){
 const drafted=stats.drafted||0,escalated=stats.escalated||0,done=stats.done||0,failed=stats.failed||0;
 const handled=drafted+escalated,autor=handled?Math.round(drafted/handled*100):0;
 const kpis=[
  {l:"Tickets processed",v:done,s:"all-time",up:true},
  {l:"AI drafts written",v:drafted,s:"ready for review",up:true},
  {l:"Escalated to you",v:escalated,s:"sensitive only",up:false},
  {l:"Automation rate",v:autor+"%",s:"drafted vs escalated",up:true},
  {l:"Failed jobs",v:failed,s:failed?"needs a look":"all clear",up:!failed,dn:!!failed},
  {l:"In queue",v:(stats.pending||0)+(stats.processing||0),s:"waiting / running",up:true}
 ];
 const pr=[["Critical",stats.critical||0,"#e5484d"],["High",stats.high||0,"#dc9309"],["Normal",stats.normal||0,"#6d5efc"],["Low",stats.low||0,"#12b76a"]];
 const mx=Math.max(1,...pr.map(x=>x[1]));const recent=tickets.slice(0,5);
 return `<div class="kpis">${kpis.map(k=>`<div class="kpi"><div class="l">${esc(k.l)}</div><div class="v">${esc(k.v)}</div><div class="s ${k.dn?'dn':(k.up?'up':'')}">${esc(k.s)}</div></div>`).join("")}</div>
 <div class="grid2">
  <div class="panel"><h3>Risk breakdown</h3><div class="ph">How your agent classified processed tickets</div>
   <div class="hb">${pr.map(p=>`<div class="r"><div class="lab">${p[0]}</div><div class="track"><div class="fill" style="width:${Math.round(p[1]/mx*100)}%;background:${p[2]}"></div></div><div class="n">${p[1]}</div></div>`).join("")}</div></div>
  <div class="panel"><h3>Recent activity</h3><div class="ph">Latest tickets your agent touched</div>
   <div class="act">${recent.length?recent.map(t=>`<div class="r"><div class="ic ${isEsc(t)?'a':'g'}">${isEsc(t)?IC.alert:IC.check}</div><div><b>${esc(nameOf(t))}</b> - ${esc(t.ticket_subject||"(no subject)")}<br><small style="color:var(--ink3)">${isEsc(t)?'Escalated to you':'AI drafted a reply'}</small></div><div class="tm">${ago(t)}</div></div>`).join(""):'<div class="hint">No tickets processed yet.</div>'}</div></div>
 </div>${learnPanel()}`;
}
function learnPanel(){
 const lt=learn.total||0,un=learn.unchanged||0,ed=learn.edited||0,base=un+ed;
 const acc=base?Math.round(un/base*100):null;
 return `<div class="sec-title">Learning over time</div>
  <div class="panel"><h3>What the agent is learning</h3><div class="ph">Every reply you approve becomes an example the agent reuses — folded in automatically each night</div>
  <div class="lrow"><div class="lstat"><div class="v">${lt}</div><div class="l">Lessons captured</div></div>
   <div class="lstat"><div class="v">${learn.sent||0}</div><div class="l">Replies sent</div></div>
   <div class="lstat"><div class="v">${acc==null?'—':acc+'%'}</div><div class="l">Sent unchanged</div></div>
   <div class="lstat"><div class="v">${ed}</div><div class="l">Edited before send</div></div></div>
  <div class="hint" style="margin-top:12px">A rising “sent unchanged” means the AI's drafts increasingly match how you reply. Personal details are stripped before anything is saved.</div></div>`;
}

function ticketsView(){
 const fl=[["all","All"],["draft","AI drafts"],["escalated","Escalated"]];
 const list=tickets.filter(t=>filter==="all"?true:filter==="escalated"?isEsc(t):!isEsc(t));
 return `<div class="filters">${fl.map(f=>`<button class="chip ${filter===f[0]?'on':''}" data-f="${f[0]}">${f[1]}</button>`).join("")}</div>
 <div class="tk">${list.length?list.map(row).join(""):'<div class="empty">No tickets here yet.</div>'}</div>`;
}
function cleanDraft(s){return (s||"").replace(/^\s*\[SENSITIVE[^\]]*\]\s*/i,"").trim();}
function cleanMessage(raw){
 const full=(raw||"").replace(/\r/g,"").trim();
 const lines=full.split("\n");const keep=[];let quoted=false,cut=0;
 for(const ln of lines){
   const s=ln.trim();
   if(/^>+/.test(s)||/^On\b.+\bwrote:?$/.test(s)||/^-{2,}\s*original message/i.test(s)||/^_{5,}$/.test(s)||/^From:\s.+/i.test(s)&&quoted){quoted=true;}
   if(quoted){cut++;continue;}
   keep.push(ln);
 }
 let main=keep.join("\n");
 main=main.replace(/https?:\/\/\S*list-manage\.com\S*/gi,"[email-preferences link]");
 main=main.replace(/https?:\/\/\S{45,}/gi,m=>m.slice(0,42)+"…");
 main=main.replace(/\n{3,}/g,"\n\n").trim();
 return {main, hasMore: cut>0 || main.length < full.length};
}
function row(t){
 const e=isEsc(t),open=openTk===String(t.message_id);
 const posted=t.note_posted?'<b>Note posted</b>':(t.job_status==='done'?'Processed':esc(t.job_status||''));
 const draft=cleanDraft(t.draft_text||"");
 let detail="";
 if(open){
   const cm=cleanMessage(t.message_text||"");
   const shown=actShowRaw?((t.message_text||"").trim()||"(empty)"):(cm.main||"(No new text — this looks like an automated or marketing email, nothing to reply to.)");
   detail=`<div class="detail"><div class="dwrap">`
    +`<div class="lab">Customer message</div>`
    +`<div class="msg">${esc(shown)}</div>`
    +(cm.hasMore?`<button class="linkbtn" id="act-raw">${actShowRaw?"Hide quoted text ▲":"Show full email & quoted text ▾"}</button>`:"");
   if(draft){
     detail+=`<div class="lab lab2">Reply to customer${t.priority?' <span class="pill">'+esc((t.priority||'').toUpperCase())+'</span>':''}</div>`;
     if(e)detail+=`<div class="warn">${IC.alert} Flagged sensitive — read carefully before sending.</div>`;
     detail+=`<textarea class="dedit" id="act-draft" spellcheck="true">${esc(actDraft)}</textarea>`;
     if(actEditOpen){
       detail+=`<div class="editbox"><div class="lab">Tell the AI how to change it</div><input id="act-instr" class="numin" placeholder="e.g. make it warmer and offer to reship free" value="${esc(actInstr)}"><div class="editact"><button class="btn p" id="act-rewrite" ${actBusy?'disabled':''}>${actBusy?'Rewriting…':'Rewrite draft'}</button><button class="btn" id="act-canceledit">Cancel</button></div></div>`;
     }
     detail+=`<div class="actbar"><span class="toast">${esc(actMsg)}</span>`+
       `<button class="btn ghost" id="act-edit" ${actBusy?'disabled':''}>Request edit</button>`+
       `<button class="btn" id="act-note" ${actBusy?'disabled':''}>Draft as internal note</button>`+
       `<button class="btn send" id="act-send" ${actBusy?'disabled':''}>Send reply →</button></div>`+
       `<div class="sendhint">“Send reply” emails the customer directly — you'll be asked to confirm.</div>`;
   }else{
     detail+=`<div class="lab lab2">Why this needs you</div><div class="draft esc">${esc(t.reason||"Escalated — handled by a human.")}</div>`;
   }
   detail+=`</div></div>`;
 }
 return `<div class="row ${open?'open':''}" data-tk="${esc(t.message_id)}" role="button" tabindex="0" aria-expanded="${open?'true':'false'}"><div class="who"><b>${esc(nameOf(t))}</b><small>${esc(t.customer_email||"")}</small></div>
  <div class="subj">${esc(t.ticket_subject||"(no subject)")}</div>
  <span class="badge ${e?'sens':'low'}">${e?'Sensitive':'AI draft'}</span>
  <div class="st">${posted}<br><small>${ago(t)}</small></div><span class="chev">${IC.chev}</span></div>${detail}`;
}
function captureAct(){const d=document.getElementById("act-draft");if(d)actDraft=d.value;const i=document.getElementById("act-instr");if(i)actInstr=i.value;}
function openTicket(mid){const t=tickets.find(x=>String(x.message_id)===String(mid));openTk=String(mid);actDraft=cleanDraft(t&&t.draft_text||"");actInstr="";actEditOpen=false;actMsg="";actBusy=false;actShowRaw=false;render();}
function curTk(){return tickets.find(x=>String(x.message_id)===openTk);}
async function sendReply(){
 captureAct();const t=curTk();if(!t)return;
 if(!actDraft.trim()){actMsg="Nothing to send.";render();return;}
 const warn=isEsc(t)?"This ticket is flagged SENSITIVE.\n\n":"";
 if(!confirm(warn+"Send this reply directly to "+(t.customer_email||"the customer")+"?"))return;
 actBusy=true;actMsg="Sending…";render();
 const meta={text:actDraft,message_text:t.message_text||"",ai_draft:cleanDraft(t.draft_text||""),customer_name:nameOf(t)};
 try{const r=await fetch(API+"/ticket/"+t.ticket_id+"/send",{method:"POST",headers:{"content-type":"application/json"},body:JSON.stringify(meta)});const j=await r.json();actMsg=r.ok?"✅ Sent to the customer":("Send failed: "+(j.error||r.status));}catch(e){actMsg="Send failed.";}
 actBusy=false;announce(actMsg);render();
}
async function noteReply(){
 captureAct();const t=curTk();if(!t)return;
 if(!actDraft.trim()){actMsg="Nothing to post.";render();return;}
 actBusy=true;actMsg="Posting internal note…";render();
 const meta={text:actDraft,message_text:t.message_text||"",ai_draft:cleanDraft(t.draft_text||""),customer_name:nameOf(t)};
 try{const r=await fetch(API+"/ticket/"+t.ticket_id+"/note",{method:"POST",headers:{"content-type":"application/json"},body:JSON.stringify(meta)});const j=await r.json();actMsg=r.ok?"✅ Posted as an internal note in Gorgias":("Failed: "+(j.error||r.status));}catch(e){actMsg="Failed.";}
 actBusy=false;announce(actMsg);render();
}
async function rewriteDraft(){
 captureAct();const t=curTk();if(!t)return;
 if(!actInstr.trim()){actMsg="Type an instruction first.";render();return;}
 actBusy=true;actMsg="AI is rewriting… (can take up to a minute)";render();
 try{const r=await fetch(API+"/ticket/"+t.ticket_id+"/rewrite",{method:"POST",headers:{"content-type":"application/json"},body:JSON.stringify({draft:actDraft,instruction:actInstr,message_text:t.message_text||""})});const j=await r.json();if(r.ok&&j.draft){actDraft=j.draft;actEditOpen=false;actInstr="";actMsg="✅ Rewritten — review it, then send.";}else{actMsg="Rewrite failed: "+(j.error||r.status);}}catch(e){actMsg="Rewrite failed.";}
 actBusy=false;announce(actMsg);render();
}

function conns(){
 const cs=[["gorgias","Gorgias","buttonsbebe.gorgias.com","Help desk - tickets in & drafts out"],["shopify","Shopify","buttons-bebe.myshopify.com","Orders & 4,246 products"],["redo","Redo","Returns & refunds","Live return status"],["whatsapp","WhatsApp alerts","Owner escalations","Linked device"],["kb","Knowledge base","22 intents - 17 policies - 5 FAQs","Auto-refreshes every 3 days"]];
 return `<div class="conns">${cs.map(c=>`<div class="conn"><div class="h"><div class="ic">${IC[c[0]]}</div><div><b>${c[1]}</b><small>${esc(c[2])}</small></div></div><span class="stt"><span class="dot"></span> Connected</span><div class="dt">${esc(c[3])}</div></div>`).join("")}</div>
 <div class="sec-title">Health</div>
 <div class="panel"><div class="act"><div class="r"><div class="ic g">${IC.check}</div><div>All services responding<br><small style="color:var(--ink3)">Gorgias, Shopify, Redo, WhatsApp and the knowledge base are healthy</small></div><div class="tm">live</div></div></div></div>`;
}

function kbView(){
 if(!kbData)return '<div class="ph2">Loading knowledge base…</div>';
 const left=(kbData.folders||[]).map(g=>`<div class="kbgroup"><div class="gh"><span>${esc(g.folder)}</span><button data-new="${esc(g.folder)}">+ new</button></div>${(g.files||[]).map(f=>`<button class="kbitem ${kbSel===f.path?'on':''}" data-open="${esc(f.path)}" title="${esc(f.path)}">${esc(f.title)}</button>`).join("")||'<div style="padding:6px 9px;color:var(--ink3);font-size:12px">empty</div>'}</div>`).join("");
 const right=kbSel
  ?`<div class="kbed"><div class="eh"><b>${esc(kbSel)}</b><div class="ef"><span class="toast">${esc(kbMsg)}</span><button class="btn p" id="kb-save">Save</button></div></div><textarea id="kb-text" spellcheck="false">${esc(kbBuf)}</textarea><div class="hint" style="margin-top:8px">Saved to the file instantly. Click <b>Re-index</b> (top right) to apply your edits to the agent's search.</div></div>`
  :`<div class="kbed"><div class="ph2">Pick a policy, FAQ, intent, or ticket on the left to edit — or use <b>+ new</b> to add one.</div></div>`;
 return `<div class="rixbar"><div class="hint">This is what your agent knows. Edits here change how it answers.</div><button class="btn" id="kb-reindex" ${kbReindexing?'disabled':''}>${kbReindexing?'Re-indexing…':'Re-index to apply'}</button></div>
 <div class="kbwrap"><div class="kblist">${left}</div>${right}</div>`;
}

function settingsView(){
 const writes=(settings.gorgias_writes_enabled||"false")==="true";
 const steps=[["Connect Gorgias","Read tickets & post reply drafts"],["Connect Shopify","Sync orders & products"],["Import knowledge base","Policies, FAQs, products"],["Set escalation channel","Sensitive tickets to WhatsApp"],["Go live","Agent drafts on new tickets"]];
 return `<div class="sec-title">Onboarding - you're all set</div>
 <div class="panel"><div class="steps">${steps.map(x=>`<div class="step"><div class="ck">${IC.check}</div><div><b>${x[0]}</b><small>${x[1]}</small></div></div>`).join("")}</div></div>
 <div class="sec-title">Agent settings</div>
 <div class="toggle"><div><b style="font-size:13.5px">Post drafts to Gorgias</b><div class="hint">On = agent posts drafts as internal notes on tickets. Off = draft-only (safe review mode).</div></div><div class="sw ${writes?'on':''}" id="f-writes" role="switch" tabindex="0" aria-checked="${writes?'true':'false'}" aria-label="Post drafts to Gorgias"><i></i></div></div>
 <div class="sec-title">Always escalate (never auto-reply)</div>
 <div class="panel"><div class="chips"><span>Refunds</span><span>Chargebacks</span><span>Damaged items</span><span>Wrong items</span><span>Cancellations</span><span>Angry customers</span></div></div>`;
}

async function loadKb(){
 kbData=await jget(KBAPI+"/list")||{folders:[]};
 if(kbData.reindex&&kbData.reindex.running){kbReindexing=true;pollReindex();}
 render();
}
async function openKbFile(p){
 kbSel=p;kbMsg="";kbBuf="Loading…";render();
 const d=await jget(KBAPI+"/file?path="+encodeURIComponent(p));
 kbBuf=d&&d.content!=null?d.content:"(failed to load)";render();
}
async function saveKb(){
 const ta=document.getElementById("kb-text");if(!ta||!kbSel)return;
 kbBuf=ta.value;kbMsg="Saving…";render();
 try{const r=await fetch(KBAPI+"/save",{method:"POST",headers:{"content-type":"application/json"},body:JSON.stringify({path:kbSel,content:kbBuf})});kbMsg=r.ok?"Saved — re-index to apply":"Save failed";}catch(e){kbMsg="Save failed";}
 announce(kbMsg);render();
}
async function newKbFile(folder){
 const name=prompt("New "+folder.slice(0,-1)+" file name (e.g. warranty):");if(!name)return;
 const tmpl="---\ntitle: "+name+"\ncategory: "+folder+"\nstatus: confirmed\ntags: []\n---\n\n## Overview\n\n";
 try{const r=await fetch(KBAPI+"/new",{method:"POST",headers:{"content-type":"application/json"},body:JSON.stringify({folder:folder,filename:name,content:tmpl})});const d=await r.json();if(r.ok){await loadKb();openKbFile(d.path);}else{alert(d.error||"could not create file");}}catch(e){alert("could not create file");}
}
async function reindexKb(){
 if(kbReindexing)return;kbReindexing=true;kbMsg="";render();
 try{await fetch(KBAPI+"/reindex",{method:"POST"});}catch(e){}
 pollReindex();
}
function pollReindex(){
 setTimeout(async()=>{
  const s=await jget(KBAPI+"/reindex-status");
  if(s&&s.running){pollReindex();}
  else{kbReindexing=false;if(tab==="kb"){kbMsg=s&&s.ok?"Re-indexed — changes are live":"Re-index finished";announce(kbMsg);render();}}
 },3000);
}

function waNum(jid){return jid?("+"+String(jid).split("@")[0]):"";}
let waSig="";
function waView(){
 if(!waData)return '<div class="ph2">Loading notification settings…</div>';
 const st=waData.state,conn=st==="connected";
 const n=waData.notify||{mode:"linked",number:""};
 if(waMode===null){waMode=n.mode||"linked";waNumber=n.number||"";}
 const accts=[["Gorgias",true],["Shopify",true],["Redo",true],["WhatsApp",conn],["Knowledge base",true]];
 const strip=accts.map(a=>`<div class="acct"><span class="dot ${a[1]?'':'off'}"></span>${esc(a[0])} <small>${a[1]?'Connected':'Not linked'}</small></div>`).join("");
 let wcard;
 if(conn){
   wcard=`<div class="wc-ok"><div class="ic g">${IC.check}</div><div><b>WhatsApp linked</b><div class="hint">Alerts arrive on ${esc(waNum(waData.owner))}</div></div><button class="btn" id="wa-unlink">Unlink</button></div>`;
 }else if(st==="qr"&&waData.qr){
   wcard=`<div class="wc-qr"><img src="${waData.qr}" alt="WhatsApp QR"><ol class="steps2"><li>Open <b>WhatsApp</b> on your phone</li><li>Tap <b>Settings → Linked devices</b></li><li>Tap <b>Link a device</b> and scan this code</li></ol></div>`;
 }else{
   wcard=`<div class="hint" style="padding:18px 0">Preparing your QR code… <span class="spin"></span></div>`;
 }
 const dest=`<div class="destbox">
   <label class="dopt ${waMode==='linked'?'on':''}"><input type="radio" name="wamode" value="linked" ${waMode==='linked'?'checked':''}> <span><b>My linked WhatsApp</b><small>Alerts go to the account linked here (most secure)</small></span></label>
   <label class="dopt ${waMode==='number'?'on':''}"><input type="radio" name="wamode" value="number" ${waMode==='number'?'checked':''}> <span><b>A specific number</b><small>Any WhatsApp number, with country code</small></span></label>
   <input class="numin" id="wa-number" placeholder="e.g. +1 555 123 4567" value="${esc(waNumber)}" ${waMode==='number'?'':'disabled'}>
   <div class="destact"><span class="toast">${esc(waMsg)}</span><button class="btn" id="wa-test" ${conn?'':'disabled'}>Send test alert</button><button class="btn p" id="wa-save">Save destination</button></div>
 </div>`;
 return `<div class="acctstrip">${strip}</div>
  <div class="grid2b">
   <div class="panel"><h3>WhatsApp alerts</h3><div class="ph">Scan once to receive escalation alerts on your phone</div>${wcard}</div>
   <div class="panel"><h3>Where alerts go</h3><div class="ph">Choose the destination for escalation notifications</div>${dest}</div>
  </div>`;
}
function stopWaPoll(){if(waPoll){clearTimeout(waPoll);waPoll=null;}}
function captureWaForm(){const mi=document.querySelector('input[name=wamode]:checked');const ni=document.getElementById("wa-number");if(mi)waMode=mi.value;if(ni)waNumber=ni.value;}
let waTick=0;
async function loadWa(){
 waData=await jget(WAAPI+"/status")||{state:"starting",notify:{mode:"linked",number:""}};
 waSig=waData.state+"|"+(waData.owner||"")+"|"+(waData.qr||"");
 waTick=0;
 render();
 stopWaPoll();
 if(tab==="notif")waPoll=setTimeout(loadWaSilent,3000);
}
async function loadWaSilent(){
 if(tab!=="notif"){stopWaPoll();return;}
 const d=await jget(WAAPI+"/status");
 if(d){
   const sig=d.state+"|"+(d.owner||"")+"|"+(d.qr||"");
   waTick++;
   // re-render whenever anything changed, and force a full refresh every 30s (10 x 3s)
   if(sig!==waSig||waTick>=10){captureWaForm();waData=d;waSig=sig;waTick=0;render();}
 }
 if(tab==="notif")waPoll=setTimeout(loadWaSilent,3000);
}
async function saveWa(){
 captureWaForm();waMsg="Saving…";render();
 try{const r=await fetch(WAAPI+"/notify",{method:"PUT",headers:{"content-type":"application/json"},body:JSON.stringify({mode:waMode,number:waNumber})});const j=await r.json();waMsg=r.ok?"Saved ✓":(j.error||"Save failed");}catch(e){waMsg="Save failed";}
 announce(waMsg);render();
}
async function testWa(){
 captureWaForm();waMsg="Sending test…";render();
 try{const r=await fetch(WAAPI+"/test",{method:"POST"});const j=await r.json();waMsg=r.ok?("Test sent to "+waNum(j.to)):(j.error||"Could not send");}catch(e){waMsg="Could not send";}
 announce(waMsg);render();
}
async function unlinkWa(){
 if(!confirm("Unlink this WhatsApp? You'll need to scan a new QR to receive alerts again."))return;
 waMsg="Unlinking…";render();
 try{await fetch(WAAPI+"/logout",{method:"POST"});}catch(e){}
 waMsg="Unlinked — scan the new QR below to re-link.";waSig="";setTimeout(loadWa,1500);announce(waMsg);render();
}
function bind(){
 document.querySelectorAll(".chip[data-f]").forEach(c=>c.onclick=()=>{filter=c.dataset.f;openTk=null;render();});
 document.querySelectorAll(".row[data-tk]").forEach(r=>{r.onclick=()=>{if(openTk===String(r.dataset.tk)){openTk=null;render();}else{openTicket(r.dataset.tk);}};keyClick(r);});
 const as=document.getElementById("act-send");if(as)as.onclick=sendReply;
 const an=document.getElementById("act-note");if(an)an.onclick=noteReply;
 const ae=document.getElementById("act-edit");if(ae)ae.onclick=()=>{captureAct();actEditOpen=!actEditOpen;render();};
 const ar=document.getElementById("act-rewrite");if(ar)ar.onclick=rewriteDraft;
 const acx=document.getElementById("act-canceledit");if(acx)acx.onclick=()=>{captureAct();actEditOpen=false;render();};
 const arw=document.getElementById("act-raw");if(arw)arw.onclick=()=>{captureAct();actShowRaw=!actShowRaw;render();};
 const w=document.getElementById("f-writes");if(w)keyClick(w);if(w)w.onclick=async()=>{const nv=!((settings.gorgias_writes_enabled||"false")==="true");settings.gorgias_writes_enabled=nv?"true":"false";render();try{await fetch(API+"/settings",{method:"PUT",headers:{"content-type":"application/json"},body:JSON.stringify({gorgias_writes_enabled:settings.gorgias_writes_enabled})});}catch(e){}};
 document.querySelectorAll("[data-open]").forEach(b=>b.onclick=()=>openKbFile(b.dataset.open));
 document.querySelectorAll("[data-new]").forEach(b=>b.onclick=()=>newKbFile(b.dataset.new));
 const ks=document.getElementById("kb-save");if(ks)ks.onclick=saveKb;
 const kr=document.getElementById("kb-reindex");if(kr)kr.onclick=reindexKb;
 const ws=document.getElementById("wa-save");if(ws)ws.onclick=saveWa;
 const wt=document.getElementById("wa-test");if(wt)wt.onclick=testWa;
 const wu=document.getElementById("wa-unlink");if(wu)wu.onclick=unlinkWa;
 document.querySelectorAll('input[name=wamode]').forEach(r=>r.onchange=()=>{captureWaForm();render();});
}
boot();
</script>
</body>
</html>
