# ─────────────────────────────────────────────────────────────────────────────
# Teddy — Buttons Bebe AI support agent
#
# Configuration lives in /root/.env (shared with gorgias-webhook).
# Copy this file only as a reference for available variables.
# NEVER commit /root/.env to git — it contains secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Gorgias ───────────────────────────────────────────────────────────────────
# Your Gorgias subdomain (the part before .gorgias.com)
GORGIAS_DOMAIN=buttonsbebe

# Email you use to log in to Gorgias
GORGIAS_EMAIL=you@buttonsbebe.com

# Gorgias API key — Settings → REST API → API Key
GORGIAS_API_KEY=your-gorgias-api-key

# ── Webhook security ──────────────────────────────────────────────────────────
# A secret you create — set the same value in Gorgias → Settings → Webhooks → Secret
WEBHOOK_SECRET=choose-a-long-random-secret

# ── LLM (AI that writes the draft reply) ─────────────────────────────────────
LLM_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
LLM_API_KEY=your-llm-api-key
LLM_MODEL=mimo-v2.5-pro

# ── Shopify (for order status lookups) ───────────────────────────────────────
# Your store name (the part before .myshopify.com)
SHOPIFY_STORE=buttons-bebe
# Scopes the app needs either way: read_orders, read_customers (read-only)
#
# Auth — pick ONE:
# (a) Mint-on-demand (recommended): the module exchanges these for a ~24h
#     access token (client_credentials grant) and auto-refreshes it.
SHOPIFY_API_KEY=your_app_client_id
SHOPIFY_API_SECRET=shpss_your_client_secret
# (b) Static token (legacy; overrides the above if set):
# SHOPIFY_ACCESS_TOKEN=shpat_your_token_here

# ── Telegram (owner notifications) ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ── Control gates ─────────────────────────────────────────────────────────────
# 0 = dry-run (safe: drafts are logged but NOT posted to Gorgias)
# 1 = live   (drafts are posted as internal notes / public replies)
# Start with 0. Switch to 1 only after you've confirmed drafts look good.
WORKFLOW_A_CONFIRM=0

# Intents that can be sent as PUBLIC replies without human review (comma-separated)
# Start with ORDER_STATUS only. Add more after you've validated quality.
AUTO_SEND_INTENTS=ORDER_STATUS

# Escalate automatically if a refund above this dollar amount is mentioned (0 = disabled)
ESCALATION_REFUND_THRESHOLD=50

# Server port (leave as 8000)
PORT=8000
