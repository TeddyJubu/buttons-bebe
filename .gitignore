# secrets
.env

# Ticket exports — contain customer PII, never commit
data/

# KB vault exemplars — derived from real tickets (PII-redacted but confidential)
build/hermes/kb-rag/vault/exemplars/

# Hermes runtime secrets / local env files
**/.env
*.env.local

# Python caches
__pycache__/
*.pyc
**/*.egg-info/

# Full VPS backup — contains plaintext secrets, never commit
_VPS-FULL-BACKUP-*/

# local .env backups (contain secrets)
.env.bak-*

# OS cruft
.DS_Store

# node/venv if ever present locally
**/node_modules/
**/.venv/

# Live service runtime state — never version or recover from the VPS
webhook/data/
processor/.processor.lock
kb/.index_kb.lock
whatsapp-connect/auth/
whatsapp-connect/notify.json

# Hermes credentials, conversations, caches, and generated runtime state
hermes/config.yaml
hermes/auth.json
hermes/auth.lock
hermes/.hermes_history
hermes/session*/
hermes/pastes/
hermes/logs/
hermes/platforms/
hermes/*cache*
hermes/processes.json
