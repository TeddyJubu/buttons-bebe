# ── Gorgias ──────────────────────────────────────────────
GORGIAS_SUBDOMAIN=buttonsbebe
GORGIAS_API_EMAIL=
GORGIAS_API_KEY=

# ── Webhook security ──────────────────────────────────────
# HMAC shared secret — set this SAME value in Gorgias HTTP Integration
WEBHOOK_SECRET=

# ── Server ───────────────────────────────────────────────
# Host the FastAPI app binds to (loopback only; Caddy proxies)
WEBHOOK_HOST=127.0.0.1
WEBHOOK_PORT=8000

# ── Queue / idempotency DB ────────────────────────────────
# SQLite path for inbox dedup + job queue
WEBHOOK_DB_PATH=./data/webhook.db

# ── Optional: Shopify ────────────────────────────────────
SHOPIFY_SHOP=buttonsbebe
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# ── Logging ──────────────────────────────────────────────
# json | text
LOG_FORMAT=json
LOG_LEVEL=INFO
