# Buttons Bebe AI Support Agent — ALL credentials & settings (single reference)
# Copy to .env and fill in real values.  Never commit a filled-in .env.
# Architecture: see CLAUDE.md (the single source of truth).

# ── Gorgias (help desk) — Basic Auth ─────────────────────────────
GORGIAS_SUBDOMAIN=buttonsbebe            # the part before .gorgias.com (no hyphen)
GORGIAS_API_EMAIL=                       # the "Username" from Gorgias > Settings > REST API
GORGIAS_API_KEY=                         # the "Password (API Key)" from that same page

# ── Shopify — client-credentials grant (mints a 24h Admin API token) ─
SHOPIFY_SHOP=buttons-bebe.myshopify.com  # full store domain (has a hyphen)
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
# SHOPIFY_API_VERSION=2026-04
# SHOPIFY_PRODUCT_QUERY=status:active     # "" = sync ALL products (incl. drafts)

# ── Redo (returns) — Bearer token ───────────────────────────────
REDO_API_KEY=
REDO_STORE_ID=

# ── Webhook receiver (bb_webhook, port 8000) ────────────────────
WEBHOOK_SECRET=                          # HMAC shared secret with Gorgias' webhook (generate: openssl rand -hex 32)
WEBHOOK_HOST=127.0.0.1
WEBHOOK_PORT=8000
WEBHOOK_DB_PATH=./data/webhook.db

# ── Processor / brain ───────────────────────────────────────────
KB_MCP_URL=http://127.0.0.1:8077/mcp     # the KB search tool
LLM_MODEL=glm-5.2                         # Hermes' model (Ollama Cloud) — see ~/.hermes/config.yaml
# LLM_BASE_URL=https://ollama.com/v1
# LLM_API_KEY=
# PROCESSOR_POLL_INTERVAL=2.0
# PROCESSOR_JOB_TIMEOUT=120
# PROCESSOR_MAX_RETRIES=3
# PROCESSOR_STALE_MINUTES=10

# ── Escalation (Twilio WhatsApp to owner) — currently a STUB ─────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=
# OWNER_WHATSAPP=

# ── Logging ─────────────────────────────────────────────────────
LOG_FORMAT=json
LOG_LEVEL=INFO
